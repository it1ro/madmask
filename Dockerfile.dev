# Development image: Ruby, SQLite tooling, Bundler.
# Node.js is omitted — Tailwind is provided by tailwindcss-rails.

FROM ruby:3.3.10-slim

ENV LANG=C.UTF-8 \
    BUNDLE_PATH=/usr/local/bundle \
    BUNDLE_JOBS=4 \
    BUNDLE_RETRY=3

# libvips: required by ruby-vips / image_processing for Active Storage variants.
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
      build-essential \
      ca-certificates \
      curl \
      openssh-client \
      docker-buildx \
      docker-cli \
      docker.io \
      git \
      libheif1 \
      libsqlite3-dev \
      libvips42 \
      libwebp7 \
      libyaml-dev \
      pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Git 2.35+ blocks repos with "dubious ownership" in containers when the
# bind-mounted working tree UID/GID differs. We explicitly allow /app
# so tools like Kamal can read git metadata inside the dev container.
RUN git config --system --add safe.directory /app
RUN git config --system --add safe.directory /app/.git

# Ensure Bundler is available explicitly (base image may ship an older pin).
RUN gem install bundler --no-document

# Rails CLI for `rails new` inside the container before the app Gemfile exists.
RUN gem install rails --no-document -v "8.1.3"

WORKDIR /app

COPY entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["bash"]

