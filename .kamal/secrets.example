# Copy to .kamal/secrets and adjust to your secret source.
# This file is safe to commit; do not put raw credentials here.
#
# Common choices:
# - ENV (recommended for quick start / CI)
# - Password manager (e.g. 1Password via `kamal secrets fetch`)
# - Rails credentials (if you expose values via `rails credentials:fetch`)

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
RAILS_MASTER_KEY=$RAILS_MASTER_KEY
