<% content_for :title, title %>
<% content_for :meta_description, meta_description if meta_description.present? %>

<section class="mx-auto w-full max-w-3xl rounded-2xl border border-line bg-card px-6 py-10 md:px-10">
  <header class="text-center">
    <h1 class="font-heading text-3xl font-semibold tracking-wide text-ink md:text-4xl">
      <%= title %>
    </h1>
    <% if lead.present? %>
      <p class="mt-3 text-sm text-ink-muted md:text-base">
        <%= lead %>
      </p>
    <% end %>
  </header>

  <% if blocks.any? %>
    <div class="mt-8 space-y-7">
      <% blocks.each do |block| %>
        <section>
          <% if block[:title].present? %>
            <h2 class="font-ui text-xs uppercase tracking-[0.14em] text-ink-muted">
              <%= block[:title] %>
            </h2>
          <% end %>
          <% if block[:body].present? %>
            <div class="prose prose-invert mt-3 max-w-none text-sm text-ink">
              <%= block[:body] %>
            </div>
          <% end %>
        </section>
      <% end %>
    </div>
  <% end %>
</section>

