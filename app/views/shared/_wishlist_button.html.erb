<div class="relative">
  <%= link_to wishlist_path,
    class:
      "group relative inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-lg border border-line bg-page/30 px-3 text-ink transition hover:border-glow hover:text-glow focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2",
    aria: { label: "Избранное" } do %>
    <svg
      class="h-5 w-5 shrink-0"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path
        d="M20.84 4.61c-1.54-1.34-3.78-1.13-5.12.31L12 8.09 8.28 4.92c-1.34-1.44-3.58-1.65-5.12-.31-1.7 1.48-1.79 4.1-.25 5.7L12 21l9.09-10.69c1.54-1.6 1.45-4.22-.25-5.7Z"
      />
    </svg>
    <span class="sr-only">Избранное</span>
  <% end %>

  <div class="absolute -right-2 -top-2">
    <%= render "shared/wishlist_counter" %>
  </div>
</div>
