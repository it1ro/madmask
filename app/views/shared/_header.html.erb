<header
  class="fixed top-0 z-50 w-full bg-[rgba(10,5,15,0.8)] backdrop-blur-[12px]"
  role="banner"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 md:px-6">
    <%= link_to root_path, class: "group flex items-center gap-2 rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent-glow)] focus-visible:outline-offset-2" do %>
      <svg
        class="h-9 w-9 shrink-0 text-[var(--color-accent-glow)] transition-[filter] duration-200 group-hover:drop-shadow-[0_0_8px_var(--color-accent-glow)]"
        viewBox="0 0 32 32"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <path
          d="M16 3C10 7 6 12 6 18c0 5 4 9 10 11 6-2 10-6 10-11 0-6-4-11-10-15z"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linejoin="round"
        />
        <ellipse cx="12" cy="16" rx="1.8" ry="2.2" fill="currentColor" opacity="0.85" />
        <ellipse cx="20" cy="16" rx="1.8" ry="2.2" fill="currentColor" opacity="0.85" />
        <path d="M13 21c1.2 1.5 2.6 2.2 4 2.2s2.8-.7 4-2.2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
      </svg>
      <span class="text-lg tracking-[0.12em] text-[var(--color-text-primary)]" style="font-family: var(--font-cinzel)">
        Madmask
      </span>
    <% end %>

    <nav class="flex flex-wrap items-center gap-4 md:gap-6" aria-label="Основная навигация">
      <%= link_to "Каталог", products_path, class: "site-nav-link #{"site-nav-link--active" if request.path.start_with?("/products")}" %>
      <span
        class="cursor-default text-xs uppercase tracking-[0.12em] text-[var(--color-text-secondary)] opacity-50"
        style="font-family: var(--font-orbitron)"
        title="Скоро"
      >
        Админ
      </span>
    </nav>
  </div>
  <div
    class="h-px w-full bg-gradient-to-r from-transparent via-[var(--color-accent-glow)] to-transparent opacity-70"
    aria-hidden="true"
  ></div>
</header>
