<header
  class="fixed top-0 z-50 w-full bg-[rgba(10,5,15,0.8)] backdrop-blur-[12px]"
  role="banner"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 md:px-6">
    <%= link_to root_path, class: "group flex items-center rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent-glow)] focus-visible:outline-offset-2" do %>
      <%= image_tag "/images/madmask-logo.png",
        alt: "Madmask",
        width: 1024,
        height: 1024,
        class: "h-8 w-auto shrink-0 object-contain transition-[filter] duration-200 md:h-9 group-hover:drop-shadow-[0_0_12px_var(--color-accent-glow)]" %>
    <% end %>

    <nav class="flex flex-wrap items-center gap-4 md:gap-6" aria-label="Основная навигация">
      <%= link_to "Каталог", products_path, class: "site-nav-link #{"site-nav-link--active" if request.path.start_with?("/products")}" %>
      <span
        class="cursor-default text-xs uppercase tracking-[0.12em] text-[var(--color-text-secondary)] opacity-50"
        style="font-family: var(--font-orbitron)"
        title="Скоро"
      >
        Админ
      </span>
    </nav>
  </div>
  <div
    class="h-px w-full bg-gradient-to-r from-transparent via-[var(--color-accent-glow)] to-transparent opacity-70"
    aria-hidden="true"
  ></div>
</header>
