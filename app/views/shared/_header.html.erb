<header
  class="fixed top-0 z-50 w-full bg-[rgba(10,5,15,0.8)] backdrop-blur-[12px]"
  role="banner"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 md:px-6">
    <%= link_to root_path,
      class:
        "header-brand-link group flex min-h-[44px] min-w-[44px] items-center rounded-md px-2 py-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2 motion-reduce:transition-none" do %>
      <%= image_tag "/images/madmask-label.png",
        alt: "Madmask",
        width: 390,
        height: 132,
        class:
          "header-brand-logo h-[3.075rem] w-auto shrink-0 object-contain transition-[filter] duration-200 md:h-[3.375rem] group-hover:drop-shadow-[0_0_12px_var(--color-accent-glow)] motion-reduce:transition-none motion-reduce:group-hover:drop-shadow-none" %>
    <% end %>

    <nav class="flex flex-wrap items-center gap-2 md:gap-6" aria-label="Основная навигация">
      <%= link_to "Каталог", products_path, class: "site-nav-link inline-flex min-h-[44px] min-w-[44px] items-center justify-center px-2 py-2 #{"site-nav-link--active" if request.path.start_with?("/products")}" %>
      <% if user_signed_in? %>
        <%= link_to "Админ",
          admin_root_path,
          class:
            "font-ui site-nav-link inline-flex min-h-[44px] min-w-[44px] items-center justify-center px-2 py-2 text-xs uppercase tracking-[0.12em] #{"site-nav-link--active" if request.path.start_with?("/admin")}" %>
      <% end %>

      <a
        href="https://vk.com/madmask73"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-md px-2 py-2 text-ink-muted transition-colors hover:text-cyber-bright focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2 motion-reduce:transition-none"
        aria-label="VK"
      >
        <svg class="h-6 w-6 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M15.07 2H8.93C3.86 2 2 3.86 2 8.93v6.14C2 20.14 3.86 22 8.93 22h6.14C20.14 22 22 20.14 22 15.07V8.93C22 3.86 20.14 2 15.07 2m3.34 14.27h-1.62c-.61 0-.8-.49-1.9-1.58-.96-.93-1.38-1.05-1.62-1.05-.33 0-.43.09-.43.55v1.44c0 .39-.12.64-1.13.64-1.67 0-3.52-1.02-4.82-2.9-1.95-2.75-2.48-4.82-2.48-5.25 0-.24.09-.46.55-.46h1.62c.41 0 .57.18.73.64.8 2.33 2.12 4.37 2.67 4.37.21 0 .31-.1.31-.63V9.65c-.06-1.06-.62-1.15-.62-1.53 0-.18.15-.36.38-.36h2.55c.34 0 .46.18.46.58v3.51c0 .37.16.5.27.5.21 0 .39-.13.78-.52 1.21-1.36 2.08-3.46 2.08-3.46.12-.27.34-.52.76-.52h1.62c.49 0 .59.25.49.58-.18.83-2.35 3.84-2.35 3.84-.19.31-.26.46 0 .78.18.25.77.75 1.16 1.21.71.83 1.25 1.53 1.4 2.01.13.48-.1.73-.52.73z"
          />
        </svg>
      </a>
    </nav>

    <div class="flex items-center gap-3">
      <details class="relative md:hidden">
        <summary
          class="list-none inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-lg border border-line bg-page/30 px-3 text-ink transition hover:border-glow hover:text-glow focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2"
          aria-label="Корзина"
        >
          <svg
            class="h-5 w-5 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M6 6h15l-2 9H7L6 6Z" />
            <path d="M6 6 5 3H2" />
            <circle cx="9" cy="20" r="1" />
            <circle cx="18" cy="20" r="1" />
          </svg>
          <span class="sr-only">Корзина</span>
        </summary>

        <div class="absolute right-0 top-full mt-2 w-72">
          <%= render "cart/popover" %>
        </div>
      </details>

      <%= render "shared/cart_button" %>
      <%= render "shared/wishlist_button" %>
    </div>
  </div>
  <div
    class="h-px w-full bg-gradient-to-r from-transparent via-[var(--color-accent-glow)] to-transparent opacity-70"
    aria-hidden="true"
  ></div>
</header>
