<span
  id="header_wishlist_counter"
  class="inline-flex min-w-[1.75rem] items-center justify-center rounded-full bg-accent-deep px-2 py-0.5 font-ui text-[11px] font-semibold tracking-[0.14em] text-ink <%= "hidden" if wishlist_count.to_i.zero? %>"
  aria-label="Товаров в избранном: <%= wishlist_count %>"
>
  <%= wishlist_count unless wishlist_count.to_i.zero? %>
</span>
