<div class="relative hidden md:block">
  <%= link_to cart_path,
    class:
      "group relative inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-lg border border-line bg-page/30 px-3 text-ink transition hover:border-glow hover:text-glow focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2",
    aria: { label: "Корзина" } do %>
    <svg
      class="h-5 w-5 shrink-0"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M6 6h15l-2 9H7L6 6Z" />
      <path d="M6 6 5 3H2" />
      <circle cx="9" cy="20" r="1" />
      <circle cx="18" cy="20" r="1" />
    </svg>
    <span class="sr-only">Корзина</span>
  <% end %>

  <div class="absolute -right-2 -top-2">
    <%= render "shared/cart_counter" %>
  </div>

  <div class="absolute right-0 top-full mt-2 w-64">
    <%= render "cart/popover" %>
  </div>
</div>
