<!DOCTYPE html>
<html lang="ru">
  <head>
    <% page_title = content_for(:title).presence || "Madmask" %>
    <title><%= page_title %></title>
    <% meta_description = content_for(:meta_description).presence %>
    <% meta_image = absolute_url(content_for(:meta_image).presence || "/images/site-hero.png") %>
    <% meta_url = content_for(:meta_url).presence || canonical_url %>
    <% meta_robots = meta_robots_content %>

    <% if meta_description.present? %>
      <meta name="description" content="<%= meta_description %>">
    <% end %>
    <% if meta_robots.present? %>
      <meta name="robots" content="<%= meta_robots %>">
    <% end %>
    <link rel="canonical" href="<%= meta_url %>">
    <meta property="og:site_name" content="Madmask">
    <meta property="og:title" content="<%= page_title %>">
    <% if meta_description.present? %>
      <meta property="og:description" content="<%= meta_description %>">
    <% end %>
    <meta property="og:type" content="<%= content_for(:og_type).presence || "website" %>">
    <meta property="og:url" content="<%= meta_url %>">
    <meta property="og:image" content="<%= meta_image %>">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= page_title %>">
    <% if meta_description.present? %>
      <meta name="twitter:description" content="<%= meta_description %>">
    <% end %>
    <meta name="twitter:image" content="<%= meta_image %>">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Madmask">
    <meta name="mobile-web-app-capable" content="yes">
    <script nonce="<%= content_security_policy_nonce %>">
      document.documentElement.classList.add("js")
    </script>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="relative flex min-h-screen flex-col antialiased">
    <a href="#main-content" class="skip-link">Перейти к содержимому</a>

    <canvas
      data-controller="cursor-smoke"
      class="cursor-smoke-canvas pointer-events-none absolute left-0 top-0 z-[5] h-screen w-screen"
      aria-hidden="true"
    ></canvas>

    <%= render "shared/header" %>
    <main
      id="main-content"
      tabindex="-1"
      class="page-main mx-auto w-full max-w-6xl flex-1 px-4 pb-12 pt-24 md:px-6 md:pt-28"
      data-controller="page-transition"
      data-page-transition-visible-class="page-main--visible"
    >
      <%= render "shared/flash" %>
      <%= yield %>
    </main>
    <%= render "shared/footer" %>

    <%# Three.js / OrbitControls: only `products#show` uses `content_for :three_js` + importmap in `:head` (IMPLEMENTATION_PLAN 4.1, OVERVIEW). %>
    <%= yield :three_js %>
  </body>
</html>
