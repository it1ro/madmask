<section class="px-4 pb-16 md:px-6 md:pb-20" aria-labelledby="inquiry-heading">
  <div class="mx-auto mt-10 w-full max-w-3xl rounded-2xl border border-line bg-card px-6 py-10 md:mt-14 md:px-10">
    <h1 id="inquiry-heading" class="font-heading text-2xl font-semibold tracking-wide text-ink md:text-3xl text-center">
      Оставь заявку
    </h1>
    <p class="mt-3 text-center text-sm text-ink-muted md:text-base">
      Опиши задачу и оставь телефон — ответим по вариантам и срокам в течение дня.
    </p>

    <% autofocus_field = %i[name phone email message].find { |attr| @inquiry.errors[attr].any? } %>

    <div class="mt-8">
      <% if @inquiry.errors.any? %>
        <div
          class="rounded-xl border border-[rgba(255,110,140,0.35)] bg-[rgba(255,110,140,0.08)] px-4 py-3 text-sm text-ink"
          role="alert"
          aria-live="polite"
          tabindex="-1"
        >
          <p class="font-ui tracking-wide">
            Проверь форму:
          </p>
          <ul class="mt-2 list-disc pl-5 text-ink-muted">
            <% @inquiry.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @inquiry, url: inquiries_path, class: "space-y-4", data: { turbo: true } do |f| %>
      <div class="hidden" aria-hidden="true">
        <%= f.label :website, "Website" %>
        <%= f.text_field :website, autocomplete: "off", tabindex: "-1" %>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <div>
          <% name_errors = @inquiry.errors.full_messages_for(:name) %>
          <% name_error_id = "inquiry_name_error" %>
          <%= f.label :name, "Имя*", class: "block text-xs font-ui uppercase tracking-[0.14em] text-ink-muted" %>
          <%= f.text_field :name,
            required: true,
            autocomplete: "name",
            maxlength: 100,
            autofocus: (autofocus_field == :name),
            "aria-invalid": name_errors.any?,
            "aria-describedby": (name_errors.any? ? name_error_id : nil),
            class: "mt-2 w-full rounded-lg border border-line bg-[rgba(10,5,15,0.35)] px-3 py-3 text-sm text-ink outline-none focus:border-[var(--color-accent-glow)] focus:ring-2 focus:ring-[rgba(183,111,224,0.25)]" %>
          <% if name_errors.any? %>
            <p id="<%= name_error_id %>" class="mt-2 text-xs text-[rgba(255,110,140,0.9)]">
              <%= name_errors.first %>
            </p>
          <% end %>
        </div>
        <div>
          <% phone_errors = @inquiry.errors.full_messages_for(:phone) %>
          <% phone_error_id = "inquiry_phone_error" %>
          <%= f.label :phone, "Телефон*", class: "block text-xs font-ui uppercase tracking-[0.14em] text-ink-muted" %>
          <%= f.telephone_field :phone,
            required: true,
            autocomplete: "tel",
            inputmode: "tel",
            placeholder: "+7…",
            maxlength: 50,
            autofocus: (autofocus_field == :phone),
            "aria-invalid": phone_errors.any?,
            "aria-describedby": (phone_errors.any? ? phone_error_id : nil),
            class: "mt-2 w-full rounded-lg border border-line bg-[rgba(10,5,15,0.35)] px-3 py-3 text-sm text-ink outline-none focus:border-[var(--color-accent-glow)] focus:ring-2 focus:ring-[rgba(183,111,224,0.25)]" %>
          <% if phone_errors.any? %>
            <p id="<%= phone_error_id %>" class="mt-2 text-xs text-[rgba(255,110,140,0.9)]">
              <%= phone_errors.first %>
            </p>
          <% end %>
        </div>
      </div>
      <div>
        <% email_errors = @inquiry.errors.full_messages_for(:email) %>
        <% email_hint_id = "inquiry_email_hint" %>
        <% email_error_id = "inquiry_email_error" %>
        <% email_describedby = [email_hint_id, (email_errors.any? ? email_error_id : nil)].compact.join(" ") %>
        <%= f.label :email, "Email", class: "block text-xs font-ui uppercase tracking-[0.14em] text-ink-muted" %>
        <%= f.email_field :email,
          autocomplete: "email",
          placeholder: "name@example.com",
          maxlength: 255,
          autofocus: (autofocus_field == :email),
          "aria-invalid": email_errors.any?,
          "aria-describedby": email_describedby,
          class: "mt-2 w-full rounded-lg border border-line bg-[rgba(10,5,15,0.35)] px-3 py-3 text-sm text-ink outline-none focus:border-[var(--color-accent-glow)] focus:ring-2 focus:ring-[rgba(183,111,224,0.25)]" %>
        <p id="<%= email_hint_id %>" class="mt-2 text-xs text-ink-muted">
          Если неудобна связь по телефону — оставь email.
        </p>
        <% if email_errors.any? %>
          <p id="<%= email_error_id %>" class="mt-2 text-xs text-[rgba(255,110,140,0.9)]">
            <%= email_errors.first %>
          </p>
        <% end %>
      </div>
      <div>
        <% message_errors = @inquiry.errors.full_messages_for(:message) %>
        <% message_error_id = "inquiry_message_error" %>
        <%= f.label :message, "Сообщение*", class: "block text-xs font-ui uppercase tracking-[0.14em] text-ink-muted" %>
        <%= f.text_area :message,
          required: true,
          rows: 6,
          maxlength: 5000,
          autofocus: (autofocus_field == :message),
          "aria-invalid": message_errors.any?,
          "aria-describedby": (message_errors.any? ? message_error_id : nil),
          class: "mt-2 w-full rounded-lg border border-line bg-[rgba(10,5,15,0.35)] px-3 py-3 text-sm text-ink outline-none focus:border-[var(--color-accent-glow)] focus:ring-2 focus:ring-[rgba(183,111,224,0.25)]" %>
        <% if message_errors.any? %>
          <p id="<%= message_error_id %>" class="mt-2 text-xs text-[rgba(255,110,140,0.9)]">
            <%= message_errors.first %>
          </p>
        <% end %>
      </div>
      <div class="pt-2 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <%= f.submit "Отправить",
          class: "hero-cta hero-cta--secondary",
          data: { disable_with: "Отправляем..." } %>
      </div>
      <% end %>
    </div>

    <div class="mt-8 text-center">
      <%= link_to "Вернуться на главную", root_path, class: "text-xs font-ui uppercase tracking-[0.14em] text-ink-muted hover:text-cyber-bright underline decoration-[var(--color-accent-glow)] underline-offset-4" %>
    </div>
  </div>
</section>
