<section class="px-4 pb-16 md:px-6 md:pb-20" aria-labelledby="inquiry-heading">
  <div class="mx-auto mt-10 w-full max-w-5xl md:mt-14">
    <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr]">
      <div class="rounded-2xl border border-line bg-card px-6 py-10 md:px-10">
        <h1 id="inquiry-heading" class="text-center font-heading text-3xl font-semibold tracking-wide text-ink md:text-4xl">
          Оставь заявку
        </h1>
        <p class="mt-3 text-center text-sm text-ink-muted md:text-base">
          Опиши задачу — мы подскажем варианты и сроки. Обычно отвечаем в течение дня.
        </p>

        <% autofocus_field = %i[name phone email message].find { |attr| @inquiry.errors[attr].any? } %>

        <div class="mt-8">
          <% if @inquiry.errors.any? %>
            <div
              class="rounded-xl border border-[rgba(255,110,140,0.35)] bg-[rgba(255,110,140,0.08)] px-4 py-3 text-sm text-ink"
              role="alert"
              aria-live="polite"
              tabindex="-1"
            >
              <p class="font-ui tracking-wide">
                Проверь форму:
              </p>
              <ul class="mt-2 list-disc pl-5 text-ink-muted">
                <% @inquiry.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with model: @inquiry,
            url: inquiries_path,
            class: "space-y-7",
            data: { turbo: true, controller: "inquiry-form", action: "input->inquiry-form#refresh blur->inquiry-form#refresh" } do |f| %>
            <div class="hidden" aria-hidden="true">
              <%= f.label :website, "Website" %>
              <%= f.text_field :website, autocomplete: "off", tabindex: "-1" %>
            </div>

            <div class="rounded-2xl border border-line bg-[rgba(10,5,15,0.22)] p-5 md:p-6">
              <div class="flex items-baseline justify-between gap-4">
                <h2 class="font-ui text-xs uppercase tracking-[0.14em] text-ink-muted">Контактная информация</h2>
                <p class="text-xs text-ink-muted">Достаточно телефона или email.</p>
              </div>

              <div class="mt-4 grid gap-4 md:grid-cols-2">
                <div class="md:col-span-2">
                  <% name_errors = @inquiry.errors.full_messages_for(:name) %>
                  <% name_hint_id = "inquiry_name_hint" %>
                  <% name_error_id = "inquiry_name_error" %>
                  <% name_describedby = [name_hint_id, (name_errors.any? ? name_error_id : nil)].compact.join(" ") %>
                  <%= f.label :name, "Имя*", class: "block text-xs font-ui uppercase tracking-[0.14em] text-ink-muted" %>
                  <%= f.text_field :name,
                    required: true,
                    autocomplete: "name",
                    maxlength: 100,
                    autofocus: (autofocus_field == :name),
                    "aria-invalid": name_errors.any?,
                    "aria-describedby": name_describedby,
                    data: { inquiry_form_target: "name" },
                    class: "mt-2 w-full rounded-lg border border-line bg-[rgba(10,5,15,0.35)] px-3 py-3 text-sm text-ink outline-none transition focus:border-[var(--color-accent-glow)] focus:ring-2 focus:ring-[rgba(183,111,224,0.25)]" %>
                  <p id="<%= name_hint_id %>" class="mt-2 text-xs text-ink-muted">
                    Как к вам обращаться?
                  </p>
                  <% if name_errors.any? %>
                    <p id="<%= name_error_id %>" class="mt-2 text-xs text-[rgba(255,110,140,0.9)]" data-inquiry-form-target="nameError">
                      <%= name_errors.first %>
                    </p>
                  <% else %>
                    <p class="mt-2 hidden text-xs text-[rgba(255,110,140,0.9)]" data-inquiry-form-target="nameError"></p>
                  <% end %>
                </div>

                <div>
                  <% phone_errors = @inquiry.errors.full_messages_for(:phone) %>
                  <% phone_hint_id = "inquiry_phone_hint" %>
                  <% phone_error_id = "inquiry_phone_error" %>
                  <% phone_describedby = [phone_hint_id, (phone_errors.any? ? phone_error_id : nil)].compact.join(" ") %>
                  <%= f.label :phone, "Телефон", class: "block text-xs font-ui uppercase tracking-[0.14em] text-ink-muted" %>
                  <%= f.telephone_field :phone,
                    autocomplete: "tel",
                    inputmode: "tel",
                    placeholder: "+7…",
                    maxlength: 50,
                    autofocus: (autofocus_field == :phone),
                    "aria-invalid": phone_errors.any?,
                    "aria-describedby": phone_describedby,
                    data: { inquiry_form_target: "phone" },
                    class: "mt-2 w-full rounded-lg border border-line bg-[rgba(10,5,15,0.35)] px-3 py-3 text-sm text-ink outline-none transition focus:border-[var(--color-accent-glow)] focus:ring-2 focus:ring-[rgba(183,111,224,0.25)]" %>
                  <p id="<%= phone_hint_id %>" class="mt-2 text-xs text-ink-muted">
                    Если удобнее — можно указать мессенджер в сообщении ниже.
                  </p>
                  <% if phone_errors.any? %>
                    <p id="<%= phone_error_id %>" class="mt-2 text-xs text-[rgba(255,110,140,0.9)]" data-inquiry-form-target="phoneError">
                      <%= phone_errors.first %>
                    </p>
                  <% else %>
                    <p class="mt-2 hidden text-xs text-[rgba(255,110,140,0.9)]" data-inquiry-form-target="phoneError"></p>
                  <% end %>
                </div>

                <div>
                  <% email_errors = @inquiry.errors.full_messages_for(:email) %>
                  <% email_hint_id = "inquiry_email_hint" %>
                  <% email_error_id = "inquiry_email_error" %>
                  <% email_describedby = [email_hint_id, (email_errors.any? ? email_error_id : nil)].compact.join(" ") %>
                  <%= f.label :email, "Email", class: "block text-xs font-ui uppercase tracking-[0.14em] text-ink-muted" %>
                  <%= f.email_field :email,
                    autocomplete: "email",
                    inputmode: "email",
                    placeholder: "name@example.com",
                    maxlength: 255,
                    autofocus: (autofocus_field == :email),
                    "aria-invalid": email_errors.any?,
                    "aria-describedby": email_describedby,
                    data: { inquiry_form_target: "email" },
                    class: "mt-2 w-full rounded-lg border border-line bg-[rgba(10,5,15,0.35)] px-3 py-3 text-sm text-ink outline-none transition focus:border-[var(--color-accent-glow)] focus:ring-2 focus:ring-[rgba(183,111,224,0.25)]" %>
                  <p id="<%= email_hint_id %>" class="mt-2 text-xs text-ink-muted">
                    Подойдёт любой рабочий адрес — ответим туда.
                  </p>
                  <% if email_errors.any? %>
                    <p id="<%= email_error_id %>" class="mt-2 text-xs text-[rgba(255,110,140,0.9)]" data-inquiry-form-target="emailError">
                      <%= email_errors.first %>
                    </p>
                  <% else %>
                    <p class="mt-2 hidden text-xs text-[rgba(255,110,140,0.9)]" data-inquiry-form-target="emailError"></p>
                  <% end %>
                </div>
              </div>

              <div class="mt-4 hidden rounded-xl border border-[rgba(255,110,140,0.35)] bg-[rgba(255,110,140,0.08)] px-4 py-3 text-sm text-ink" data-inquiry-form-target="contactGroupError">
                Укажи телефон или email — как удобнее.
              </div>
            </div>

            <div class="rounded-2xl border border-line bg-[rgba(10,5,15,0.22)] p-5 md:p-6">
              <h2 class="font-ui text-xs uppercase tracking-[0.14em] text-ink-muted">Описание задачи</h2>
              <div class="mt-4">
                <% message_errors = @inquiry.errors.full_messages_for(:message) %>
                <% message_hint_id = "inquiry_message_hint" %>
                <% message_error_id = "inquiry_message_error" %>
                <% message_describedby = [message_hint_id, (message_errors.any? ? message_error_id : nil)].compact.join(" ") %>
                <%= f.label :message, "Сообщение*", class: "block text-xs font-ui uppercase tracking-[0.14em] text-ink-muted" %>
                <%= f.text_area :message,
                  required: true,
                  rows: 7,
                  maxlength: 5000,
                  autofocus: (autofocus_field == :message),
                  "aria-invalid": message_errors.any?,
                  "aria-describedby": message_describedby,
                  data: { inquiry_form_target: "message" },
                  class: "mt-2 w-full rounded-lg border border-line bg-[rgba(10,5,15,0.35)] px-3 py-3 text-sm text-ink outline-none transition focus:border-[var(--color-accent-glow)] focus:ring-2 focus:ring-[rgba(183,111,224,0.25)]" %>
                <p id="<%= message_hint_id %>" class="mt-2 text-xs text-ink-muted">
                  Опиши задачу в свободной форме: что нужно, пожелания, сроки (если важны). Можно добавить ссылку.
                </p>
                <% if message_errors.any? %>
                  <p id="<%= message_error_id %>" class="mt-2 text-xs text-[rgba(255,110,140,0.9)]" data-inquiry-form-target="messageError">
                    <%= message_errors.first %>
                  </p>
                <% else %>
                  <p class="mt-2 hidden text-xs text-[rgba(255,110,140,0.9)]" data-inquiry-form-target="messageError"></p>
                <% end %>
              </div>
            </div>

            <div class="pt-1">
              <%= f.submit "Отправить заявку",
                class: "hero-cta hero-cta--secondary w-full justify-center transition",
                data: { disable_with: "Отправляем...", inquiry_form_target: "submit" } %>
              <p class="mt-3 text-center text-xs text-ink-muted">
                Нажимая «Отправить заявку», ты соглашаешься на обработку данных для ответа по заявке.
              </p>
            </div>
          <% end %>
        </div>

        <div class="mt-8 text-center">
          <%= link_to "Вернуться на главную", root_path, class: "text-xs font-ui uppercase tracking-[0.14em] text-ink-muted hover:text-cyber-bright underline decoration-[var(--color-accent-glow)] underline-offset-4" %>
        </div>
      </div>

      <aside class="rounded-2xl border border-line bg-card px-6 py-10 md:px-8 lg:sticky lg:top-8">
        <h2 class="font-heading text-xl font-semibold tracking-wide text-ink">Почему стоит оставить заявку</h2>
        <p class="mt-3 text-sm text-ink-muted">
          Коротко про процесс — чтобы было спокойно и понятно.
        </p>
        <ul class="mt-6 space-y-3 text-sm text-ink">
          <li class="flex gap-3">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[var(--color-accent-glow)]"></span>
            <span><span class="text-ink-muted">Срок ответа:</span> обычно в течение дня</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[var(--color-accent-glow)]"></span>
            <span><span class="text-ink-muted">Подбор решения:</span> предложим варианты по бюджету и срокам</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-[var(--color-accent-glow)]"></span>
            <span><span class="text-ink-muted">Прозрачность:</span> уточним детали до начала работ</span>
          </li>
        </ul>

        <div class="mt-8 rounded-2xl border border-line bg-[rgba(10,5,15,0.22)] p-5">
          <p class="text-xs font-ui uppercase tracking-[0.14em] text-ink-muted">Что можно приложить</p>
          <p class="mt-2 text-sm text-ink">
            Ссылку на пример/референс, фото, страницу в соцсетях — всё, что поможет быстрее оценить задачу.
          </p>
        </div>
      </aside>
    </div>
  </div>
</section>
