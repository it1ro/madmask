<% content_for :title, "Новый товар — Madmask" %>

<section class="py-4 md:py-8" aria-labelledby="new-product-heading">
  <h1 id="new-product-heading" class="font-heading text-3xl font-semibold tracking-wide text-ink md:text-4xl">
    Новый товар
  </h1>
  <p class="mt-2 text-ink-muted">
    <%= link_to "← К админке", admin_products_path, class: "text-cyber underline-offset-2 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2 rounded-sm" %>
  </p>

  <div class="mt-8 max-w-2xl rounded-2xl border border-line bg-card p-6">
    <%= render "form", product: @product, form_html: { data: { turbo: false } } %>
  </div>
</section>
