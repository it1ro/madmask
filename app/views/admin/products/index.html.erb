<% content_for :title, "Админ — товары — Madmask" %>

<section class="py-4 md:py-8" aria-labelledby="admin-catalog-heading">
  <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
    <div>
      <h1 id="admin-catalog-heading" class="font-heading text-3xl font-semibold tracking-wide text-ink md:text-4xl">
        Управление каталогом
      </h1>
      <p class="mt-2 max-w-xl text-ink-muted">
        Создание и редактирование товаров. Публичный каталог —
        <%= link_to "на сайте", products_path, class: "text-cyber underline-offset-2 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2 rounded-sm" %>.
      </p>
    </div>
    <%= link_to "Добавить (отдельная страница)",
      new_admin_product_path,
      data: { turbo_frame: "_top" },
      class:
        "font-ui inline-flex min-h-[44px] shrink-0 items-center justify-center self-start rounded-lg border border-accent px-4 py-2 text-xs font-medium uppercase tracking-wide text-ink transition hover:bg-accent-deep focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2 md:self-auto" %>
  </div>

  <div class="mt-10 space-y-10">
    <%= render "product_form_container", product: @product %>

    <div>
      <h2 class="font-heading mb-4 text-lg font-semibold tracking-wide text-ink">
        Все товары
      </h2>
      <div id="products" class="flex flex-col gap-5">
        <% if @products.any? %>
          <%= render partial: "admin/products/product", collection: @products, as: :product %>
        <% else %>
          <p id="products_empty" class="rounded-xl border border-dashed border-line bg-card/60 px-6 py-10 text-center text-ink-faint">
            Пока нет товаров — добавьте первый через форму выше.
          </p>
        <% end %>
      </div>

      <% if defined?(@pagy) && @pagy.pages > 1 %>
        <nav class="mt-10 flex justify-center">
          <%== @pagy.series_nav %>
        </nav>
      <% end %>
    </div>
  </div>
</section>
