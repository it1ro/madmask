<%# locals: product: %>
<%= turbo_frame_tag dom_id(product) do %>
  <article
    class="group relative overflow-hidden rounded-2xl border border-line bg-card p-5 shadow-card transition duration-200 hover:-translate-y-1.5 hover:shadow-[0_0_18px_var(--color-accent-glow),inset_0_0_0_1px_rgba(183,111,224,0.12)] motion-reduce:transform-none motion-reduce:transition-none"
    style="--product-cat: <%= product_category_css_var(product.category) %>"
  >
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
      <div
        class="relative h-36 w-full shrink-0 overflow-hidden rounded-xl border border-line bg-panel sm:h-32 sm:w-32"
      >
        <% hero = product.hero_image %>
        <% if hero.present? %>
          <%= image_tag hero.variant(resize_to_limit: [512, 512]),
            class: "h-full w-full object-cover",
            alt: "" %>
        <% else %>
          <div
            class="flex h-full w-full items-center justify-center text-xs text-ink-faint"
            aria-hidden="true"
          >
            Нет обложки
          </div>
        <% end %>
      </div>

      <div class="min-w-0 flex-1">
        <div class="flex flex-wrap items-start justify-between gap-2">
          <h2 class="font-heading text-lg font-semibold tracking-wide text-ink md:text-xl">
            <%= link_to product.name, product_path(product), class: "hover:text-glow focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2 rounded-sm" %>
          </h2>
          <span
            class="inline-flex shrink-0 rounded-full px-2.5 py-0.5 font-ui text-xs font-medium uppercase tracking-wider text-page"
            style="background: var(--product-cat)"
          >
            <%= product_category_label(product.category) %>
          </span>
        </div>

        <% if product.description.present? %>
          <p class="mt-2 line-clamp-2 text-sm text-ink-muted">
            <%= product.description %>
          </p>
        <% end %>

        <p class="mt-3 font-mono text-lg text-price">
          <%= number_to_currency(product.price, unit: "₽", separator: ",", delimiter: " ", format: "%n %u") %>
        </p>

        <div class="mt-4 flex flex-wrap gap-3">
          <%= link_to "Подробнее",
            product_path(product),
            data: { turbo_frame: "_top" },
            class:
              "font-ui inline-flex min-h-[40px] items-center justify-center rounded-lg border border-accent px-4 py-2 text-xs font-medium uppercase tracking-wide text-ink transition hover:bg-accent-deep focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2" %>
          <%= link_to "Редактировать",
            edit_admin_product_path(product),
            data: { turbo_frame: dom_id(product) },
            class:
              "font-ui inline-flex min-h-[40px] items-center justify-center rounded-lg border border-line px-4 py-2 text-xs text-ink-muted transition hover:border-cyber hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2" %>
          <%= button_to "Удалить",
            admin_product_path(product),
            method: :delete,
            form: { data: { turbo_confirm: "Удалить «#{product.name}»?" } },
            class:
              "font-ui inline-flex min-h-[40px] cursor-pointer items-center justify-center rounded-lg border border-transparent bg-transparent px-4 py-2 text-xs text-[var(--color-category-horror)] underline-offset-2 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2" %>
        </div>
      </div>
    </div>
  </article>
<% end %>
