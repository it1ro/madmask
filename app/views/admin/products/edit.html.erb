<% content_for :title, "Редактировать — #{@product.translated_name} — Madmask" %>

<section class="py-4 md:py-8" aria-labelledby="edit-product-heading">
  <h1
    id="edit-product-heading"
    class="sr-only"
  >
    Редактировать <%= @product.translated_name %>
  </h1>
  <p class="mb-6 text-ink-muted">
    <%= link_to "← К админке", admin_products_path, class: "text-cyber underline-offset-2 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2 rounded-sm" %>
  </p>

  <%= turbo_frame_tag dom_id(@product) do %>
    <div class="rounded-2xl border border-line bg-card p-6 shadow-[0_0_24px_rgba(0,0,0,0.35)]">
      <h2 class="font-heading mb-4 text-xl font-semibold tracking-wide text-ink md:text-2xl">
        Редактировать
      </h2>
      <%= render "form", product: @product %>
    </div>
  <% end %>
</section>
