<% content_for :title, "Редактировать — #{@product.name} — Madmask" %>

<section class="py-4 md:py-8" aria-labelledby="edit-product-heading">
  <h1
    id="edit-product-heading"
    class="sr-only"
  >
    Редактировать <%= @product.name %>
  </h1>
  <p class="mb-6 text-[var(--color-text-secondary)]">
    <%= link_to "← К админке", admin_products_path, class: "text-[var(--color-accent-cyber)] underline-offset-2 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent-glow)] focus-visible:outline-offset-2 rounded-sm" %>
  </p>

  <%= turbo_frame_tag dom_id(@product) do %>
    <div
      class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-secondary)] p-6 shadow-[0_0_24px_rgba(0,0,0,0.35)]"
    >
      <h2
        class="mb-4 text-xl font-semibold tracking-wide text-[var(--color-text-primary)] md:text-2xl"
        style="font-family: var(--font-cinzel)"
      >
        Редактировать
      </h2>
      <%= render "form", product: @product %>
    </div>
  <% end %>
</section>
