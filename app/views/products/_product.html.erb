<%# locals: product: %>
<article
  class="group relative overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-secondary)] p-5 shadow-[0_0_20px_rgba(0,0,0,0.25)] transition duration-200 hover:-translate-y-1.5 hover:shadow-[0_0_18px_var(--color-accent-glow)] motion-reduce:transform-none motion-reduce:transition-none"
  style="--product-cat: <%= product_category_css_var(product.category) %>"
>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
    <div
      class="relative h-36 w-full shrink-0 overflow-hidden rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] sm:h-32 sm:w-32"
    >
      <% hero = product.hero_image %>
      <% if hero.present? %>
        <%= image_tag hero.variant(resize_to_limit: [512, 512]),
          class: "h-full w-full object-cover",
          alt: "" %>
        <% if product.gallery_extra_count.positive? %>
          <span
            class="pointer-events-none absolute bottom-1.5 right-1.5 rounded-md border border-[var(--color-accent-cyber)]/60 bg-[var(--color-bg-primary)]/90 px-1.5 py-0.5 text-[0.6875rem] font-medium leading-none text-[var(--color-accent-cyber)] shadow-sm"
            style="font-family: var(--font-jetbrains)"
            aria-label="Дополнительных фотографий в галерее: <%= product.gallery_extra_count %>"
          >
            +<%= product.gallery_extra_count %>
          </span>
        <% end %>
      <% else %>
        <div
          class="flex h-full w-full items-center justify-center text-xs text-[var(--color-text-muted)]"
          aria-hidden="true"
        >
          Нет обложки
        </div>
      <% end %>
    </div>

    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-start justify-between gap-2">
        <h2
          class="text-lg font-semibold tracking-wide text-[var(--color-text-primary)] md:text-xl"
          style="font-family: var(--font-cinzel)"
        >
          <%= link_to product.name, product_path(product), class: "hover:text-[var(--color-accent-glow)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent-glow)] focus-visible:outline-offset-2 rounded-sm" %>
        </h2>
        <span
          class="inline-flex shrink-0 rounded-full px-2.5 py-0.5 text-xs font-medium uppercase tracking-wider text-[var(--color-bg-primary)]"
          style="font-family: var(--font-orbitron); background: var(--product-cat)"
        >
          <%= product_category_label(product.category) %>
        </span>
      </div>

      <% if product.description.present? %>
        <p class="mt-2 line-clamp-2 text-sm text-[var(--color-text-secondary)]">
          <%= product.description %>
        </p>
      <% end %>

      <p class="mt-3 text-lg text-[var(--color-text-accent)]" style="font-family: var(--font-jetbrains)">
        <%= number_to_currency(product.price, unit: "₽", separator: ",", delimiter: " ", format: "%n %u") %>
      </p>

      <div class="mt-4 flex flex-wrap gap-3">
        <%= link_to "Подробнее",
          product_path(product),
          class:
            "inline-flex min-h-[40px] items-center justify-center rounded-lg border border-[var(--color-accent-1)] px-4 py-2 text-xs font-medium uppercase tracking-wide text-[var(--color-text-primary)] transition hover:bg-[var(--color-accent-2)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent-glow)] focus-visible:outline-offset-2",
          style: "font-family: var(--font-orbitron)" %>
      </div>
    </div>
  </div>

  <% if product.model_file.attached? %>
    <div
      class="mt-4 flex flex-col gap-2 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-primary)]/50 bg-gradient-to-r from-[var(--color-bg-primary)]/90 to-[var(--color-accent-2)]/25 px-4 py-3 shadow-[inset_0_0_0_1px_rgba(183,111,224,0.12)] sm:flex-row sm:items-center sm:justify-between"
      role="region"
      aria-label="Интерактивное 3D превью"
    >
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-accent-cyber)]" style="font-family: var(--font-orbitron)">
        3D на странице товара
      </p>
      <%= link_to "Открыть 3D превью",
        product_path(product, anchor: "product-3d-preview"),
        class:
          "inline-flex min-h-[40px] shrink-0 items-center justify-center rounded-lg border border-[var(--color-accent-cyber)] px-3 py-2 text-xs font-medium text-[var(--color-text-primary)] transition hover:bg-[var(--color-accent-2)]/80 focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent-glow)] focus-visible:outline-offset-2" %>
    </div>
  <% end %>
</article>
