<%# locals: product: %>
<article
  class="group relative overflow-hidden rounded-2xl border border-line bg-card p-4 shadow-card transition duration-200 hover:-translate-y-1.5 hover:shadow-[0_0_18px_var(--color-accent-glow),inset_0_0_0_1px_rgba(183,111,224,0.14)] motion-reduce:transform-none motion-reduce:transition-none sm:p-5"
  style="--product-cat: <%= product_category_css_var(product.category) %>"
>
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
    <%= link_to product_path(product),
      aria: { label: "Открыть товар: #{product.name}" },
      class:
        "group/cover relative block h-32 w-full shrink-0 overflow-hidden rounded-xl border border-line bg-panel transition hover:border-glow hover:shadow-[0_0_18px_var(--color-accent-glow)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2 sm:h-32 sm:w-32" do %>
      <% if product.cover_image.attached? %>
        <%= image_tag product.cover_image.variant(resize_to_limit: [512, 512]),
          class: "h-full w-full object-cover",
          alt: product.name,
          loading: "lazy",
          decoding: "async" %>
      <% else %>
        <div
          class="flex h-full w-full items-center justify-center text-xs text-ink-faint"
          aria-hidden="true"
        >
          Нет обложки
        </div>
      <% end %>
    <% end %>

    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-start justify-between gap-2">
        <h2 class="font-heading text-lg font-semibold tracking-wide text-ink md:text-xl">
          <%= link_to product.name, product_path(product), class: "rounded-sm transition active:opacity-80 hover:text-glow focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2 motion-reduce:active:opacity-100" %>
        </h2>
        <span
          class="inline-flex shrink-0 rounded-full px-2.5 py-0.5 font-ui text-xs font-medium uppercase tracking-wider text-page"
          style="background: var(--product-cat)"
        >
          <%= product_category_label(product.category) %>
        </span>
      </div>

      <% if product.description.present? %>
        <p class="mt-2 line-clamp-2 text-sm text-ink-muted sm:line-clamp-2">
          <%= product.description %>
        </p>
      <% end %>

      <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-2 sm:mt-3">
        <p class="font-mono text-lg text-price">
          <%= number_to_currency(product.price, unit: "₽", separator: ",", delimiter: " ", format: "%n %u") %>
        </p>
        <% if product.model_file.attached? %>
          <span
            class="inline-flex items-center rounded-full border border-cyber/70 bg-page/40 px-2.5 py-1 font-ui text-[10px] font-semibold uppercase tracking-[0.18em] text-cyber"
            aria-label="Доступно 3D превью на странице товара"
          >
            3D доступно
          </span>
        <% end %>
      </div>

      <div class="mt-3 flex flex-wrap gap-3 sm:mt-4">
        <%= link_to "Подробнее",
          product_path(product),
          class:
            "inline-flex min-h-[44px] items-center justify-center rounded-lg border border-accent px-4 py-2 font-ui text-xs font-medium uppercase tracking-wide text-ink transition active:scale-[0.98] hover:scale-[1.02] hover:shadow-[0_0_18px_var(--color-accent-glow)] hover:bg-accent-deep focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2 motion-reduce:active:scale-100 motion-reduce:transform-none motion-reduce:transition-none" %>
      </div>

      <div class="mt-3 sm:mt-4">
        <%= render "products/actions", product: product %>
      </div>
    </div>
  </div>

  <% if product.model_file.attached? %>
    <div
      class="mt-3 flex flex-col gap-2 rounded-xl border border-line bg-page/50 bg-gradient-to-r from-page/90 to-accent-deep/25 px-4 py-3 shadow-[inset_0_0_0_1px_rgba(183,111,224,0.12)] sm:mt-4 sm:flex-row sm:items-center sm:justify-between"
      role="region"
      aria-label="Интерактивное 3D превью"
    >
      <p class="font-ui text-xs font-semibold uppercase tracking-[0.18em] text-cyber">
        3D на странице товара
      </p>
      <%= link_to "Открыть 3D превью",
        product_path(product, anchor: "product-3d-preview"),
        aria: { label: "Перейти к интерактивному 3D на странице товара: #{product.name}" },
        class:
          "inline-flex min-h-[44px] shrink-0 items-center justify-center rounded-lg border border-cyber px-3 py-2 font-ui text-xs font-medium text-ink transition active:scale-[0.98] hover:scale-[1.02] hover:shadow-[0_0_18px_var(--color-accent-glow)] hover:bg-accent-deep/80 focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2 motion-reduce:active:scale-100 motion-reduce:transform-none motion-reduce:transition-none" %>
    </div>
  <% end %>
</article>
