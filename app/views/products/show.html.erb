<% content_for :title, "#{@product.name} — Madmask" %>

<%# Three.js 0.170: pins in config/importmap.rb; Stimulus webgl_preview loads via dynamic import on this page only. %>

<article class="py-4 md:py-8">
  <p class="mb-6">
    <%= link_to "← К каталогу",
      products_path,
      class:
        "inline-flex min-h-[44px] items-center text-sm text-[var(--color-accent-cyber)] underline-offset-2 transition active:scale-[0.98] hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent-glow)] focus-visible:outline-offset-2 rounded-sm motion-reduce:active:scale-100" %>
  </p>

  <div class="grid gap-8 lg:grid-cols-[minmax(0,3fr)_minmax(0,2fr)] lg:gap-12">
    <div class="flex flex-col gap-6">
      <% preview_images = @product.preview_images_ordered %>
      <% if preview_images.any? %>
        <% gallery_slides = preview_images.map do |blob_or_attached|
          lb800 = blob_or_attached.variant(resize_to_limit: [800, 800])
          lb2400 = blob_or_attached.variant(resize_to_limit: [2400, 2400])
          { src: url_for(lb2400), srcset: "#{url_for(lb800)} 800w, #{url_for(lb2400)} 2400w" }
        end %>
        <section
          class="overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]"
          aria-label="Фотографии товара"
        >
          <%= tag.div(
            class: "p-3 sm:p-4",
            data: {
              controller: "product-gallery",
              product_gallery_slides_value: gallery_slides.to_json
            }
          ) do %>
            <% main_img = preview_images.first %>
            <% main_v800 = main_img.variant(resize_to_limit: [800, 800]) %>
            <% main_v1200 = main_img.variant(resize_to_limit: [1200, 1200]) %>
            <button
              type="button"
              class="group relative aspect-[4/3] w-full cursor-zoom-in overflow-hidden rounded-xl border border-[var(--color-border)]/80 bg-[var(--color-bg-primary)]/30 text-left motion-reduce:transition-none transition-[box-shadow] duration-200 hover:shadow-[0_0_0_1px_var(--color-accent-glow),0_0_20px_rgba(183,111,224,0.15)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent-glow)] focus-visible:outline-offset-2"
              data-action="click->product-gallery#openLightbox"
              aria-label="Открыть фото в полный размер"
            >
              <%= image_tag url_for(main_v1200),
                srcset: "#{url_for(main_v800)} 800w, #{url_for(main_v1200)} 1200w",
                sizes: "(max-width: 640px) 100vw, 90vw",
                class:
                  "pointer-events-none absolute inset-0 block h-full w-full object-cover object-center motion-reduce:transition-none transition-opacity duration-200 group-hover:opacity-95",
                alt: @product.name,
                data: { product_gallery_target: "main" } %>
            </button>
            <% if preview_images.many? %>
              <div
                class="mt-3 flex gap-2 overflow-x-auto scroll-smooth pb-1 [-ms-overflow-style:none] [scrollbar-width:none] motion-reduce:scroll-auto [&::-webkit-scrollbar]:hidden snap-x snap-mandatory"
                role="tablist"
                aria-label="Миниатюры"
              >
                <% preview_images.each_with_index do |blob_or_attached, i| %>
                  <% thumb = blob_or_attached.variant(resize_to_limit: [120, 120]) %>
                  <% large800 = blob_or_attached.variant(resize_to_limit: [800, 800]) %>
                  <% large1200 = blob_or_attached.variant(resize_to_limit: [1200, 1200]) %>
                  <button
                    type="button"
                    class="shrink-0 snap-start overflow-hidden rounded-lg border-2 border-transparent bg-[var(--color-bg-primary)]/40 motion-reduce:transition-none transition-[border-color] duration-150 aria-selected:border-[var(--color-accent-cyber)] aria-selected:ring-1 aria-selected:ring-[var(--color-accent-cyber)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent-glow)] focus-visible:outline-offset-2 active:opacity-90"
                    style="min-width: 4.5rem; min-height: 4.5rem"
                    data-product-gallery-thumb="true"
                    data-gallery-index="<%= i %>"
                    data-action="click->product-gallery#select"
                    data-thumb-url="<%= url_for(thumb) %>"
                    data-thumb-src="<%= url_for(thumb) %>"
                    data-thumb-main-url="<%= url_for(large1200) %>"
                    data-thumb-srcset="<%= "#{url_for(large800)} 800w, #{url_for(large1200)} 1200w" %>"
                    role="tab"
                    aria-selected="<%= i.zero? %>"
                    aria-label="Выбрать кадр <%= i + 1 %>"
                  >
                    <%= image_tag thumb,
                      class: "h-[4.5rem] w-[4.5rem] object-cover",
                      alt: "" %>
                  </button>
                <% end %>
              </div>
            <% end %>

            <%# Fullscreen lightbox: larger variants (2400px), arrows, Escape / backdrop to close %>
            <div
              data-product-gallery-target="dialog"
              class="product-gallery-lightbox fixed inset-0 z-[200] hidden p-3 sm:p-6"
              role="dialog"
              aria-modal="true"
              aria-label="Просмотр фотографии"
              hidden
              data-action="click->product-gallery#closeLightbox"
            >
              <div
                class="absolute inset-0 bg-[rgba(5,2,10,0.92)] backdrop-blur-sm motion-reduce:backdrop-blur-none"
                aria-hidden="true"
              ></div>
              <div
                class="relative z-10 flex max-h-[min(92dvh,100vh)] w-full max-w-[min(96vw,100vw)] items-center justify-center gap-1 sm:gap-3"
                data-action="click->product-gallery#stopPropagation"
              >
                <button
                  type="button"
                  data-product-gallery-target="prevButton"
                  class="product-gallery-lightbox-nav inline-flex min-h-[56px] min-w-[56px] shrink-0 touch-manipulation items-center justify-center rounded-xl border-2 border-[var(--color-border)]/80 bg-[var(--color-surface)]/90 px-2 text-4xl leading-none text-[var(--color-text-primary)] shadow-md motion-reduce:transition-none transition-opacity hover:border-[var(--color-accent-cyber)] hover:text-[var(--color-accent-cyber)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent-glow)] focus-visible:outline-offset-2 disabled:pointer-events-none disabled:opacity-0 sm:min-h-[4.5rem] sm:min-w-[4.5rem] sm:px-3 sm:text-5xl"
                  data-action="click->product-gallery#showPrevious"
                  aria-label="Предыдущее фото"
                >
                  <span aria-hidden="true">‹</span>
                </button>
                <div class="flex min-h-0 min-w-0 flex-1 items-center justify-center">
                  <% lb0 = gallery_slides.first %>
                  <%= image_tag lb0.fetch(:src),
                    srcset: lb0.fetch(:srcset),
                    alt: @product.name,
                    sizes: "(max-width: 640px) 96vw, min(92vw, 2400px)",
                    class:
                      "max-h-[min(88dvh,92vh)] max-w-full object-contain object-center shadow-[0_0_40px_rgba(0,0,0,0.45)] motion-reduce:transition-none transition-opacity duration-150 #{preview_images.many? ? "cursor-pointer" : "cursor-default"}",
                    data: {
                      product_gallery_target: "lightboxImage"
                    }.merge(preview_images.many? ? { action: "click->product-gallery#showNext" } : {}) %>
                </div>
                <button
                  type="button"
                  data-product-gallery-target="nextButton"
                  class="product-gallery-lightbox-nav inline-flex min-h-[56px] min-w-[56px] shrink-0 touch-manipulation items-center justify-center rounded-xl border-2 border-[var(--color-border)]/80 bg-[var(--color-surface)]/90 px-2 text-4xl leading-none text-[var(--color-text-primary)] shadow-md motion-reduce:transition-none transition-opacity hover:border-[var(--color-accent-cyber)] hover:text-[var(--color-accent-cyber)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent-glow)] focus-visible:outline-offset-2 disabled:pointer-events-none disabled:opacity-0 sm:min-h-[4.5rem] sm:min-w-[4.5rem] sm:px-3 sm:text-5xl"
                  data-action="click->product-gallery#showNext"
                  aria-label="Следующее фото"
                >
                  <span aria-hidden="true">›</span>
                </button>
              </div>
              <button
                type="button"
                class="product-gallery-lightbox-nav absolute right-3 top-3 z-20 inline-flex min-h-[56px] min-w-[56px] shrink-0 touch-manipulation items-center justify-center rounded-xl border-2 border-[var(--color-border)]/80 bg-[var(--color-surface)]/90 px-2 text-4xl leading-none text-[var(--color-text-primary)] shadow-md motion-reduce:transition-none transition-opacity hover:border-[var(--color-accent-cyber)] hover:text-[var(--color-accent-cyber)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent-glow)] focus-visible:outline-offset-2 sm:right-5 sm:top-5 sm:min-h-[4.5rem] sm:min-w-[4.5rem] sm:px-3 sm:text-5xl"
                data-action="click->product-gallery#closeLightbox"
                aria-label="Закрыть просмотр"
                data-product-gallery-focus-on-open="true"
              >
                <span aria-hidden="true">×</span>
              </button>
            </div>
          <% end %>
        </section>
      <% else %>
        <section
          class="overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]"
          aria-label="Фотографии товара"
        >
          <div class="flex aspect-[4/3] w-full items-center justify-center px-4 py-8">
            <p class="text-center text-sm text-[var(--color-text-muted)]">Нет фотографий</p>
          </div>
        </section>
      <% end %>

      <%# 3D preview only when GLB/GLTF is attached; no placeholder block otherwise. %>
      <% if @product.model_file.attached? %>
        <section
          id="product-3d-preview"
          class="relative w-full overflow-hidden rounded-2xl border border-[var(--color-border)] bg-gradient-to-br from-[var(--color-bg-primary)] to-[var(--color-accent-2)] shadow-[0_0_28px_rgba(183,111,224,0.18)]"
          aria-labelledby="product-3d-heading"
        >
          <div class="flex items-center justify-between gap-3 border-b border-[var(--color-border)]/80 bg-[var(--color-bg-secondary)]/40 px-4 py-3">
            <h2
              id="product-3d-heading"
              class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-text-secondary)]"
              style="font-family: var(--font-orbitron)"
            >
              3D превью
            </h2>
            <span class="truncate text-xs text-[var(--color-text-muted)]" title="<%= @product.model_file.filename %>">
              <%= @product.model_file.filename %>
            </span>
          </div>
          <%# Description for figure — must stay outside canvas-container (Stimulus clears the node). %>
          <span id="product-3d-desc" class="sr-only">Интерактивное вращение модели мышью или касанием.</span>
          <div
            id="canvas-container"
            class="relative aspect-square w-full min-h-[min(80vw,28rem)] sm:min-h-[22rem]"
            data-controller="webgl-preview"
            data-webgl-preview-model-url-value="<%= h(@product.effective_model_url.to_s) %>"
            role="figure"
            aria-labelledby="product-3d-heading"
            aria-describedby="product-3d-desc"
          ></div>
        </section>
      <% end %>
    </div>

    <div
      class="product-show-info"
      data-controller="reveal-on-scroll"
      data-reveal-on-scroll-revealed-class="product-show-info--revealed"
    >
      <div class="product-show-info__inner">
        <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-text-muted)]" style="font-family: var(--font-orbitron)">
          <%= product_category_label(@product.category) %>
        </p>
        <h1
          class="mt-2 text-3xl font-semibold tracking-wide text-[var(--color-text-primary)] md:text-4xl"
          style="font-family: var(--font-cinzel)"
        >
          <%= @product.name %>
        </h1>
        <p class="mt-4 text-2xl text-[var(--color-text-accent)]" style="font-family: var(--font-jetbrains)">
          <%= number_to_currency(@product.price, unit: "₽", separator: ",", delimiter: " ", format: "%n %u") %>
        </p>

        <% if @product.description.present? %>
          <div class="mt-6 max-w-prose whitespace-pre-line text-[var(--color-text-secondary)] leading-relaxed">
            <%= @product.description %>
          </div>
        <% end %>

        <% contact_href = product_contact_mailto_url(@product) %>
        <div class="mt-8">
          <% if contact_href.present? %>
            <%= link_to "Связаться",
              contact_href,
              class: "product-cta cta-pulse-shadow inline-flex w-full min-h-[44px] justify-center sm:w-auto sm:min-w-[12rem]" %>
          <% else %>
            <button
              type="button"
              disabled
              class="product-cta inline-flex w-full min-h-[44px] cursor-not-allowed justify-center opacity-50 sm:w-auto sm:min-w-[12rem]"
            >
              Связаться
            </button>
            <p class="mt-2 text-xs text-[var(--color-text-muted)]">
              Контакт для связи не настроен. Для администратора: env <code class="rounded bg-[var(--color-surface)] px-1 py-0.5 text-[0.7rem]">MADMASK_CONTACT_EMAIL</code> или credentials <code class="rounded bg-[var(--color-surface)] px-1 py-0.5 text-[0.7rem]">madmask.contact_email</code>.
            </p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</article>
