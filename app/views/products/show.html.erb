<% content_for :title, "#{@product.name} — Madmask" %>

<%# Three.js 0.170: pins in config/importmap.rb; Stimulus webgl_preview loads via dynamic import on this page only. %>

<article class="py-4 md:py-8">
  <p class="mb-6">
    <%= link_to "← К каталогу",
      products_path,
      class:
        "inline-flex min-h-[44px] items-center text-sm text-[var(--color-accent-cyber)] underline-offset-2 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent-glow)] focus-visible:outline-offset-2 rounded-sm" %>
  </p>

  <div class="grid gap-8 lg:grid-cols-2 lg:gap-12">
    <div
      class="relative aspect-square w-full max-w-xl overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] lg:max-w-none"
    >
      <%# IMPLEMENTATION_PLAN 4.3: canvas mount for WebGL (Stimulus webgl-preview, iteration 5). %>
      <div
        id="canvas-container"
        class="absolute inset-0 z-10"
        data-controller="webgl-preview"
        data-webgl-preview-model-url-value="<%= @product.model_url %>"
        aria-label="3D preview"
      ></div>
      <% if @product.cover_image.attached? %>
        <%= image_tag @product.cover_image,
          class:
            "pointer-events-none absolute inset-0 -z-0 h-full w-full object-cover",
          alt: @product.name %>
      <% else %>
        <div
          class="pointer-events-none absolute inset-0 -z-0 flex h-full w-full items-center justify-center text-[var(--color-text-muted)]"
        >
          Нет обложки
        </div>
      <% end %>
    </div>

    <div>
      <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-text-muted)]" style="font-family: var(--font-orbitron)">
        <%= product_category_label(@product.category) %>
      </p>
      <h1
        class="mt-2 text-3xl font-semibold tracking-wide text-[var(--color-text-primary)] md:text-4xl"
        style="font-family: var(--font-cinzel)"
      >
        <%= @product.name %>
      </h1>
      <p class="mt-4 text-2xl text-[var(--color-text-accent)]" style="font-family: var(--font-jetbrains)">
        <%= number_to_currency(@product.price, unit: "₽", separator: ",", delimiter: " ", format: "%n %u") %>
      </p>

      <% if @product.description.present? %>
        <div class="mt-6 max-w-prose whitespace-pre-line text-[var(--color-text-secondary)] leading-relaxed">
          <%= @product.description %>
        </div>
      <% end %>

      <% if @product.model_url.present? %>
        <p class="mt-6 text-sm text-[var(--color-text-muted)]">
          3D-модель:
          <%= link_to @product.model_url,
            @product.model_url,
            target: "_blank",
            rel: "noopener noreferrer",
            class: "break-all text-[var(--color-accent-cyber)] underline-offset-2 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent-glow)] focus-visible:outline-offset-2" %>
        </p>
      <% end %>
    </div>
  </div>
</article>
