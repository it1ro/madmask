<% content_for :title, "#{@product.name} — Madmask" %>

<%# Three.js 0.170: pins in config/importmap.rb; Stimulus webgl_preview loads via dynamic import on this page only. %>

<article class="py-4 md:py-8">
  <p class="mb-6">
    <%= link_to "← К каталогу",
      products_path,
      class:
        "inline-flex min-h-[44px] items-center text-sm text-[var(--color-accent-cyber)] underline-offset-2 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent-glow)] focus-visible:outline-offset-2 rounded-sm" %>
  </p>

  <div class="grid gap-8 lg:grid-cols-[minmax(0,3fr)_minmax(0,2fr)] lg:gap-12">
    <div class="flex flex-col gap-6">
      <% preview_images = @product.preview_images_ordered %>
      <% if preview_images.any? %>
        <section
          class="overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]"
          aria-label="Фотографии товара"
        >
          <div
            data-controller="product-gallery"
            class="p-3 sm:p-4"
          >
            <% main_img = preview_images.first %>
            <% main_variant = main_img.variant(resize_to_limit: [1200, 1200]) %>
            <div class="relative aspect-[4/3] w-full max-w-xl overflow-hidden rounded-xl border border-[var(--color-border)]/80 bg-[var(--color-bg-primary)]/30 sm:max-w-md">
              <%= image_tag main_variant,
                class:
                  "h-full w-full object-cover motion-reduce:transition-none transition-opacity duration-200",
                alt: @product.name,
                data: { product_gallery_target: "main" } %>
            </div>
            <% if preview_images.many? %>
              <div
                class="mt-3 flex gap-2 overflow-x-auto scroll-smooth pb-1 [-ms-overflow-style:none] [scrollbar-width:none] motion-reduce:scroll-auto [&::-webkit-scrollbar]:hidden snap-x snap-mandatory"
                role="tablist"
                aria-label="Миниатюры"
              >
                <% preview_images.each_with_index do |blob_or_attached, i| %>
                  <% thumb = blob_or_attached.variant(resize_to_limit: [120, 120]) %>
                  <button
                    type="button"
                    class="shrink-0 snap-start overflow-hidden rounded-lg border-2 border-transparent bg-[var(--color-bg-primary)]/40 motion-reduce:transition-none transition-[border-color] duration-150 aria-selected:border-[var(--color-accent-cyber)] aria-selected:ring-1 aria-selected:ring-[var(--color-accent-cyber)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-[var(--color-accent-glow)] focus-visible:outline-offset-2"
                    style="min-width: 4.5rem; min-height: 4.5rem"
                    data-product-gallery-thumb="true"
                    data-action="click->product-gallery#select"
                    data-thumb-url="<%= url_for(thumb) %>"
                    role="tab"
                    aria-selected="<%= i.zero? %>"
                    aria-label="Кадр <%= i + 1 %>"
                  >
                    <%= image_tag thumb,
                      class: "h-[4.5rem] w-[4.5rem] object-cover",
                      alt: "" %>
                  </button>
                <% end %>
              </div>
            <% end %>
          </div>
        </section>
      <% else %>
        <section
          class="overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)]"
          aria-label="Фотографии товара"
        >
          <div class="flex aspect-[4/3] max-w-xl items-center justify-center px-4 py-8 sm:max-w-md">
            <p class="text-center text-sm text-[var(--color-text-muted)]">Нет фотографий</p>
          </div>
        </section>
      <% end %>

      <%# 3D preview below photos; anchor for catalog links. %>
      <section
        id="product-3d-preview"
        class="relative w-full overflow-hidden rounded-2xl border border-[var(--color-border)] bg-gradient-to-br from-[var(--color-bg-primary)] to-[var(--color-accent-2)] shadow-[0_0_28px_rgba(183,111,224,0.18)]"
        aria-labelledby="product-3d-heading"
      >
        <div class="flex items-center justify-between gap-3 border-b border-[var(--color-border)]/80 bg-[var(--color-bg-secondary)]/40 px-4 py-3">
          <h2
            id="product-3d-heading"
            class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-text-secondary)]"
            style="font-family: var(--font-orbitron)"
          >
            3D превью
          </h2>
          <% if @product.model_file.attached? %>
            <span class="truncate text-xs text-[var(--color-text-muted)]" title="<%= @product.model_file.filename %>">
              <%= @product.model_file.filename %>
            </span>
          <% end %>
        </div>
        <div
          id="canvas-container"
          class="relative aspect-square w-full min-h-[min(80vw,28rem)] sm:min-h-[22rem]"
          data-controller="webgl-preview"
          data-webgl-preview-model-url-value="<%= h(@product.effective_model_url.to_s) %>"
          aria-label="Интерактивная 3D-модель"
        ></div>
      </section>
    </div>

    <div>
      <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-text-muted)]" style="font-family: var(--font-orbitron)">
        <%= product_category_label(@product.category) %>
      </p>
      <h1
        class="mt-2 text-3xl font-semibold tracking-wide text-[var(--color-text-primary)] md:text-4xl"
        style="font-family: var(--font-cinzel)"
      >
        <%= @product.name %>
      </h1>
      <p class="mt-4 text-2xl text-[var(--color-text-accent)]" style="font-family: var(--font-jetbrains)">
        <%= number_to_currency(@product.price, unit: "₽", separator: ",", delimiter: " ", format: "%n %u") %>
      </p>

      <% if @product.description.present? %>
        <div class="mt-6 max-w-prose whitespace-pre-line text-[var(--color-text-secondary)] leading-relaxed">
          <%= @product.description %>
        </div>
      <% end %>

    </div>
  </div>
</article>
