<% content_for :title, "Редактировать — #{@product.name} — Madmask" %>

<%= turbo_frame_tag dom_id(@product) do %>
  <div
    class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-secondary)] p-6 shadow-[0_0_24px_rgba(0,0,0,0.35)]"
  >
    <h2
      class="mb-4 text-xl font-semibold tracking-wide text-[var(--color-text-primary)] md:text-2xl"
      style="font-family: var(--font-cinzel)"
    >
      Редактировать
    </h2>
    <%= render "form", product: @product %>
  </div>
<% end %>
