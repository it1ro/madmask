<%# locals: product: %>
<div
  id="product_card_actions_<%= product.id %>"
  class="flex flex-wrap items-center gap-2"
>
  <%= button_to(
    "В корзину",
    cart_add_path(product_id: product.id),
    method: :post,
    class:
      "inline-flex min-h-[44px] items-center justify-center rounded-lg border border-accent px-4 py-2 font-ui text-xs font-semibold uppercase tracking-wide text-ink transition active:scale-[0.98] hover:bg-accent-deep hover:shadow-[0_0_18px_var(--color-accent-glow)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2 motion-reduce:transform-none motion-reduce:transition-none"
  ) %>

  <%= button_to(
    in_wishlist?(product.id) ? "В избранном" : "В избранное",
    wishlist_toggle_path(product_id: product.id),
    method: :post,
    aria: { pressed: in_wishlist?(product.id) },
    class:
      "inline-flex min-h-[44px] items-center justify-center rounded-lg border border-line bg-page/40 px-4 py-2 font-ui text-xs font-semibold uppercase tracking-wide text-ink transition active:scale-[0.98] hover:border-glow hover:shadow-[0_0_18px_var(--color-accent-glow)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2 motion-reduce:transform-none motion-reduce:transition-none"
  ) %>

  <% qty = cart_qty(product.id) %>
  <% if qty.positive? %>
    <span class="inline-flex min-h-[28px] items-center rounded-full border border-line bg-panel px-2.5 font-ui text-[10px] font-semibold uppercase tracking-[0.16em] text-ink-muted">
      В корзине: <%= qty %>
    </span>
  <% end %>
</div>
