<% content_for :title, "Каталог — Madmask" %>

<section
  class="py-4 md:py-8"
  aria-labelledby="catalog-heading"
  data-controller="catalog-loading"
>
  <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
    <div>
      <h1 id="catalog-heading" class="font-heading text-3xl font-semibold tracking-wide text-ink md:text-4xl">
        Каталог
      </h1>
      <p class="mt-2 max-w-xl text-ink-muted">
        Маски и артефакты коллекции. Управление товарами — в
        <%= link_to "админ-панели", admin_root_path, class: "text-cyber underline-offset-2 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2 rounded-sm" %>.
      </p>
    </div>
  </div>

  <div class="mt-10">
    <div class="mb-4 flex flex-col gap-1 md:flex-row md:items-baseline md:justify-between">
      <h2 class="font-heading text-lg font-semibold tracking-wide text-ink">
        Все товары
      </h2>
      <p class="font-ui text-xs uppercase tracking-wide text-ink-muted">
        <%= @results_count %> <%= russian_plural(@results_count, "товар", "товара", "товаров") %>
        <% if @current_category.present? %>
          <span class="text-ink-faint">·</span>
          <span>жанр: <%= product_category_label(@current_category) %></span>
        <% end %>
      </p>
    </div>

    <% chip_inactive_classes =
      "inline-flex items-center justify-center rounded-full border border-line bg-card/40 px-4 py-2 font-ui text-xs font-medium uppercase tracking-wide text-ink-muted transition hover:scale-[1.02] hover:bg-card/60 hover:border-glow hover:shadow-[0_0_18px_var(--color-accent-glow)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2 active:scale-[0.98] motion-reduce:active:scale-100 motion-reduce:transform-none motion-reduce:transition-none" %>
    <% chip_active_classes =
      "inline-flex items-center justify-center rounded-full border border-glow bg-accent-deep px-4 py-2 font-ui text-xs font-medium uppercase tracking-wide text-page transition hover:scale-[1.02] hover:bg-accent-deep/90 hover:shadow-[0_0_28px_var(--color-accent-glow)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2 active:scale-[0.98] motion-reduce:active:scale-100 motion-reduce:transform-none motion-reduce:transition-none" %>

    <div class="mb-8" role="group" aria-label="Фильтры по жанру">
      <div class="flex flex-wrap items-center gap-3">
        <div class="flex flex-col gap-1">
          <span class="font-ui text-xs uppercase tracking-wide text-ink-muted">
            Жанры
          </span>
          <span class="text-xs text-ink-faint">
            Выберите жанр, чтобы сузить каталог.
          </span>
        </div>
        <div class="flex flex-wrap gap-2">
          <%= link_to "Все",
            products_path,
            class: (@current_category.blank? ? chip_active_classes : chip_inactive_classes),
            aria: { current: (@current_category.blank? ? "page" : nil) } %>

          <% Product::CATEGORIES.each do |category| %>
            <%= link_to product_category_label(category),
              products_path(category: category),
              class: (@current_category == category ? chip_active_classes : chip_inactive_classes),
              aria: { current: (@current_category == category ? "page" : nil) } %>
          <% end %>

          <% if @current_category.present? %>
            <%= link_to "Сбросить",
              products_path,
              class: chip_inactive_classes,
              aria: { label: "Сбросить фильтр по жанру" } %>
          <% end %>
        </div>
      </div>
    </div>

    <div
      id="products"
      class="relative flex flex-col gap-5"
      data-catalog-loading-target="list"
    >
      <div
        class="pointer-events-none absolute inset-0 z-10 hidden items-center justify-center rounded-2xl bg-page/20 backdrop-blur-[1px]"
        data-catalog-loading-target="indicator"
        aria-hidden="true"
      >
        <div class="flex items-center gap-3 rounded-full border border-line bg-card/70 px-4 py-2 shadow-card">
          <span class="h-4 w-4 animate-spin rounded-full border-2 border-ink-faint border-t-cyber motion-reduce:animate-none"></span>
          <span class="font-ui text-xs font-semibold uppercase tracking-[0.18em] text-ink-muted">Загрузка</span>
        </div>
      </div>
      <% if @products.any? %>
        <%= render partial: "products/product", collection: @products, as: :product %>
      <% else %>
        <p id="products_empty" class="rounded-xl border border-dashed border-line bg-card/60 px-6 py-10 text-center text-ink-faint">
          Пока нет товаров.
        </p>
      <% end %>
    </div>

    <% if defined?(@pagy) && @pagy.pages > 1 %>
      <nav class="mt-10 flex justify-center">
        <%== @pagy.series_nav %>
      </nav>
    <% end %>
  </div>
</section>
