<% content_for :title, "Каталог — Madmask" %>

<section class="py-4 md:py-8" aria-labelledby="catalog-heading">
  <h1
    id="catalog-heading"
    class="text-3xl font-semibold tracking-wide text-[var(--color-text-primary)] md:text-4xl"
    style="font-family: var(--font-cinzel)"
  >
    Каталог
  </h1>
  <p class="mt-3 max-w-xl text-[var(--color-text-secondary)]">
    Скоро здесь появятся маски и артефакты. Пока заглушка для маршрута каталога (итерация 3).
  </p>
  <p class="mt-6">
    <%= link_to "На главную", root_path, class: "site-nav-link inline-flex min-h-[44px] items-center rounded-md px-2 py-2" %>
  </p>
</section>
