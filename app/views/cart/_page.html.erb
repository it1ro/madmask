<div id="cart_page">
  <% items = cart_contract.list %>
  <% products = cart_products_by_id %>
  <div class="rounded-2xl border border-line bg-card p-5 shadow-card">
    <h1 class="font-heading text-xl font-semibold tracking-wide text-ink">Корзина</h1>

    <% if items.empty? %>
      <p class="mt-3 text-ink-muted">Корзина пуста.</p>
    <% else %>
      <ul class="mt-4 space-y-3">
        <% items.each do |row| %>
          <% product = products[row[:product_id]] %>
          <li class="flex flex-wrap items-center justify-between gap-3 rounded-xl border border-line bg-page/30 px-4 py-3">
            <div class="min-w-0">
              <p class="truncate font-ui text-sm font-semibold text-ink">
                <%= product&.name || "##{row[:product_id]}" %>
              </p>
              <% if product %>
                <p class="mt-0.5 text-xs text-ink-muted">
                  <%= number_to_currency(product.price, unit: "₽", separator: ",", delimiter: " ", format: "%n %u") %>
                </p>
              <% end %>
            </div>

            <div class="flex items-center gap-2">
              <%= button_to "-",
                cart_path(product_id: row[:product_id], qty: row[:qty].to_i - 1),
                method: :patch,
                class:
                  "inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-lg border border-line bg-panel/60 font-ui text-sm font-semibold text-ink transition hover:border-glow focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2" %>

              <span class="min-w-[2.5rem] text-center font-mono text-sm text-ink-muted"><%= row[:qty] %></span>

              <%= button_to "+",
                cart_path(product_id: row[:product_id], qty: row[:qty].to_i + 1),
                method: :patch,
                class:
                  "inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-lg border border-line bg-panel/60 font-ui text-sm font-semibold text-ink transition hover:border-glow focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2" %>

              <%= button_to "Удалить",
                remove_cart_path(product_id: row[:product_id]),
                method: :post,
                class:
                  "inline-flex min-h-[44px] items-center justify-center rounded-lg border border-line bg-page/40 px-3 font-ui text-xs font-semibold uppercase tracking-[0.16em] text-ink-muted transition hover:border-glow hover:text-ink focus-visible:outline focus-visible:outline-2 focus-visible:outline-glow focus-visible:outline-offset-2" %>
            </div>
          </li>
        <% end %>
      </ul>

      <div class="mt-5 flex items-center justify-between rounded-xl border border-line bg-panel/40 px-4 py-3">
        <p class="font-ui text-xs font-semibold uppercase tracking-[0.18em] text-ink-muted">Итого</p>
        <p class="font-mono text-base text-ink">
          <%= number_to_currency(cart_subtotal, unit: "₽", separator: ",", delimiter: " ", format: "%n %u") %>
        </p>
      </div>
    <% end %>
  </div>
</div>
