<%= turbo_frame_tag "cart_popover" do %>
  <div class="rounded-xl border border-line bg-panel/80 p-3 shadow-card">
    <div class="flex items-center justify-between gap-3">
      <p class="font-ui text-xs font-semibold uppercase tracking-[0.18em] text-ink-muted">Корзина</p>
    </div>

    <% items = cart_contract.list %>
    <% products = cart_products_by_id %>
    <% if items.empty? %>
      <p class="mt-2 text-sm text-ink-muted">Пока пусто.</p>
    <% else %>
      <ul class="mt-2 space-y-1">
        <% items.first(5).each do |row| %>
          <% product = products[row[:product_id]] %>
          <li class="flex items-center justify-between gap-3 text-sm text-ink">
            <div class="min-w-0">
              <p class="truncate text-sm text-ink">
                <%= product&.name || "##{row[:product_id]}" %>
              </p>
              <% if product %>
                <p class="text-xs text-ink-muted">
                  <%= number_to_currency(product.price, unit: "₽", separator: ",", delimiter: " ", format: "%n %u") %>
                </p>
              <% end %>
            </div>
            <div class="text-right">
              <p class="font-mono text-sm text-ink-muted"><%= row[:qty] %>×</p>
              <% if product %>
                <p class="font-mono text-xs text-ink-faint">
                  <%= number_to_currency(product.price.to_i * row[:qty].to_i, unit: "₽", separator: ",", delimiter: " ", format: "%n %u") %>
                </p>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>

      <% if items.size > 5 %>
        <p class="mt-2 text-xs text-ink-faint">И ещё <%= items.size - 5 %>…</p>
      <% end %>

      <div class="mt-3 flex items-center justify-between border-t border-line pt-2">
        <p class="font-ui text-xs font-semibold uppercase tracking-[0.16em] text-ink-muted">Итого</p>
        <p class="font-mono text-sm text-ink">
          <%= number_to_currency(cart_subtotal, unit: "₽", separator: ",", delimiter: " ", format: "%n %u") %>
        </p>
      </div>
    <% end %>
  </div>
<% end %>
